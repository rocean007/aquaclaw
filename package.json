    "chalk": "^5.3.0",
    "ora": "^8.1.1",
    "conf": "^13.0.0",
    "chokidar": "^4.0.3",
    "cron": "^3.2.1",
    "uuid": "^10.0.0",
    "dotenv": "^16.4.7",
    "zod": "^3.23.8",
    "marked": "^12.0.0",
    "eventsource": "^2.0.2",
    "node-whisper": "^0.0.11",
