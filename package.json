    "gateway": "node src/gateway/index.mjs",
    "gateway:watch": "node --watch src/gateway/index.mjs",
    "aquaclaw": "node packages/cli/bin/aquaclaw.mjs",
    "ui:dev": "node src/ui/server.mjs",
    "test": "node --test test/**/*.test.mjs",
    "lint": "node scripts/lint.mjs",
    "onboard": "node packages/cli/bin/aquaclaw.mjs onboard"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "express": "^4.21.2",
    "node-fetch": "^3.3.2",
    "commander": "^12.1.0",
