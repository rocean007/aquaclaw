{
  "agent": {
    "model": "claude-opus-4-6",
    "instructions": "You are my personal AI assistant. Be concise and proactive.",
    "maxContextTokens": 100000
  },
  "models": {
    "anthropicApiKey": "sk-ant-...",
    "openaiApiKey": "sk-..."
  },
  "gateway": {
    "port": 18790,
    "bind": "loopback",
    "dmPolicy": "pairing"
  },
  "channels": {
    "webchat": {
      "enabled": true
    },
    "telegram": {
      "enabled": false,
      "botToken": "123456:ABCDEF",
      "allowFrom": ["your_telegram_id"],
      "dmPolicy": "pairing"
    },
    "discord": {
      "enabled": false,
      "token": "your_discord_bot_token",
      "dmPolicy": "pairing"
    },
    "slack": {
      "enabled": false,
      "botToken": "xoxb-...",
      "appToken": "xapp-..."
    },
    "whatsapp": {
      "enabled": false,
      "allowFrom": ["*"]
    },
    "webhook": {
      "enabled": false,
      "path": "/webhook/inbound",
      "secret": "your-webhook-secret"
    },
    "rss": {
      "enabled": false,
      "feeds": [
        "https://hnrss.org/frontpage",
        "https://feeds.arstechnica.com/arstechnica/index"
      ],
      "pollInterval": 300000
    }
  },
  "voice": {
    "enabled": false,
    "stt": "whisper",
    "tts": "system",
    "wakeWords": ["hey shark", "aquaclaw"],
    "wakeWord": {
      "enabled": false
    }
  },
  "cron": [
  ],
  "agents": {
    "defaults": {
      "workspace": "~/.aquaclaw/workspace",
      "sandbox": {
        "mode": "off"
      }
    }
  }
}
